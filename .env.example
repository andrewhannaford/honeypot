# Copy this file to .env and fill in your values

# Discord webhook for alerts (leave blank to disable)
DISCORD_WEBHOOK_URL=

# AbuseIPDB API key for threat intel enrichment (leave blank to disable)
ABUSEIPDB_API_KEY=

# Gemini API key for LLM-enhanced fake shell (leave blank to disable)
GEMINI_API_KEY=

# Discord alert toggles — 0/false/no/off to disable (default: enabled)
# ALERT_ON_CONNECT=1
# ALERT_ON_CREDENTIAL=1
# ALERT_ON_EXEC=1
# ALERT_ON_DOWNLOAD=1

# Seconds between duplicate Discord alerts for the same IP + alert type (bad values → 60)
# DISCORD_ALERT_COOLDOWN=60

# Honeypot location for attack-map SSE arcs (decimal degrees)
# SERVER_LAT=51.5074
# SERVER_LON=-0.1278

# Network interface Suricata should sniff (run "ip link show" to find yours)
# SURICATA_IFACE=ens33
