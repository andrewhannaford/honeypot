# Honeypot Detection Rules
# "any -> any" so these fire regardless of HOME_NET / public IP

# --- Port Scan Detection ---
alert tcp any any -> any 22 (msg:"HONEYPOT SSH Connection Attempt"; flags:S; threshold:type both, count 3, seconds 60, track by_src; classtype:attempted-recon; sid:1000001; rev:2;)
alert tcp any any -> any 80 (msg:"HONEYPOT HTTP Connection Attempt"; flags:S; threshold:type both, count 5, seconds 60, track by_src; classtype:attempted-recon; sid:1000002; rev:2;)
alert tcp any any -> any 21 (msg:"HONEYPOT FTP Connection Attempt"; flags:S; threshold:type both, count 3, seconds 60, track by_src; classtype:attempted-recon; sid:1000003; rev:2;)
alert tcp any any -> any 23 (msg:"HONEYPOT Telnet Connection Attempt"; flags:S; threshold:type both, count 3, seconds 60, track by_src; classtype:attempted-recon; sid:1000004; rev:2;)
alert tcp any any -> any 25 (msg:"HONEYPOT SMTP Connection Attempt"; flags:S; threshold:type both, count 3, seconds 60, track by_src; classtype:attempted-recon; sid:1000005; rev:2;)
alert tcp any any -> any 6379 (msg:"HONEYPOT Redis Connection Attempt"; flags:S; threshold:type both, count 3, seconds 60, track by_src; classtype:attempted-recon; sid:1000006; rev:2;)

# --- HTTP Exploit Probes ---
alert http any any -> any any (msg:"HONEYPOT WordPress wp-login.php Probe"; http.uri; content:"/wp-login.php"; classtype:web-application-attack; sid:1000010; rev:1;)
alert http any any -> any any (msg:"HONEYPOT .env File Disclosure Probe"; http.uri; content:"/.env"; classtype:web-application-attack; sid:1000011; rev:1;)
alert http any any -> any any (msg:"HONEYPOT PHP Webshell Probe"; http.uri; content:".php"; http.request_body; content:"cmd="; classtype:web-application-attack; sid:1000012; rev:1;)
alert http any any -> any any (msg:"HONEYPOT Shell Command in HTTP Body"; http.request_body; content:"wget "; nocase; classtype:web-application-attack; sid:1000013; rev:1;)
alert http any any -> any any (msg:"HONEYPOT Shell Command in HTTP Body"; http.request_body; content:"curl "; nocase; classtype:web-application-attack; sid:1000014; rev:1;)

# --- Redis Exploitation ---
alert tcp any any -> any 6379 (msg:"HONEYPOT Redis CONFIG SET Attack"; content:"CONFIG"; nocase; content:"SET"; nocase; classtype:attempted-admin; sid:1000020; rev:1;)
alert tcp any any -> any 6379 (msg:"HONEYPOT Redis SLAVEOF Attack"; content:"SLAVEOF"; nocase; classtype:attempted-admin; sid:1000021; rev:1;)
alert tcp any any -> any 6379 (msg:"HONEYPOT Redis EVAL Code Execution"; content:"EVAL"; nocase; classtype:attempted-admin; sid:1000022; rev:1;)
alert tcp any any -> any 6379 (msg:"HONEYPOT Redis Cron Payload"; content:"* * * *"; classtype:attempted-admin; sid:1000023; rev:1;)

# --- Reverse Shell Payloads ---
alert tcp any any -> any any (msg:"HONEYPOT Reverse Shell /dev/tcp"; content:"/dev/tcp/"; classtype:shellcode-detect; sid:1000030; rev:1;)
alert tcp any any -> any any (msg:"HONEYPOT Reverse Shell bash -i"; content:"bash -i"; nocase; classtype:shellcode-detect; sid:1000031; rev:1;)
alert tcp any any -> any any (msg:"HONEYPOT Netcat Reverse Shell"; content:"nc -e"; nocase; classtype:shellcode-detect; sid:1000032; rev:1;)

# --- Download Attempts ---
alert tcp any any -> any any (msg:"HONEYPOT wget Download Attempt"; content:"wget "; content:"http"; within:100; classtype:policy-violation; sid:1000040; rev:1;)
alert tcp any any -> any any (msg:"HONEYPOT curl Download Attempt"; content:"curl "; content:"http"; within:100; classtype:policy-violation; sid:1000041; rev:1;)
